// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            Int         @id @default(autoincrement())
  username      String      @unique
  discriminator String      @default("0000") // Discord-style 4-digit tag e.g. #4821
  avatar        String      // Path or avatar slug
  bio           String?
  email         String?     @unique
  supabaseUid   String?     @unique
  createdAt     DateTime    @default(now())
  posts         Post[]
  comments      Comment[]
  votes         Vote[]
  ownedDens     Den[]       @relation("DenOwner")
  joinedDens    DenMember[]
  joinedChannels ChannelMember[]
}

model Den {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  slug        String       @unique
  description String
  banner      String?      // Banner style/color/image
  icon        String?      // Icon initials or custom style
  createdAt   DateTime     @default(now())
  ownerId     Int?
  owner       User?        @relation("DenOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  passcode    String       @default("1234") // Invite passcode to protect entry
  channels    Channel[]
  posts       Post[]
  members     DenMember[]
}

model DenMember {
  id       Int      @id @default(autoincrement())
  denId    Int
  den      Den      @relation(fields: [denId], references: [id], onDelete: Cascade)
  userId   Int
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([denId, userId])
}

model Channel {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String
  type      String   @default("TEXT") // "TEXT" or "VOICE"
  password  String?  // Optional password to join/lock private channels
  denId     Int
  den       Den      @relation(fields: [denId], references: [id], onDelete: Cascade)
  posts     Post[]
  createdAt DateTime @default(now())

  members   ChannelMember[]

  @@unique([denId, slug])
}

model Post {
  id        Int       @id @default(autoincrement())
  title     String
  content   String
  imageUrl  String?
  tags      String    @default("Discussion") // Comma-separated list of tags
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  authorId  Int
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  denId     Int
  den       Den       @relation(fields: [denId], references: [id], onDelete: Cascade)
  channelId Int
  channel   Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  comments  Comment[]
  votes     Vote[]
}

model Comment {
  id        Int       @id @default(autoincrement())
  content   String
  createdAt DateTime  @default(now())
  postId    Int
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  Int
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId  Int?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
}

model Vote {
  id     Int  @id @default(autoincrement())
  value  Int  // 1 for upvote, -1 for downvote
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model ChannelMember {
  id        Int      @id @default(autoincrement())
  channelId Int
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([channelId, userId])
}
